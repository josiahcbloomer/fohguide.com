<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | FOHGuide.com</title>
  <link rel="stylesheet" href="/assets/css/base.css">

  {% if isArticle %}
    <link rel="stylesheet" href="/assets/css/article.css">
  {% endif %}
  
  {% if requiredGear %}
    <meta name="protected-gear-slug" content="{{ requiredGear }}">
  {% endif %}
  {% if isFree %}
    <meta name="article-is-free" content="true">
  {% endif %}
</head>
<body>
  
  <header>
    <nav>
      <a href="/">Home</a>
      <!-- You can loop through gear dynamically here later -->
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

</body>
</html>